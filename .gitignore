# ------------------------------------------------------------------ #
# Python
# ------------------------------------------------------------------ #
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.ipynb_checkpoints/

# ------------------------------------------------------------------ #
# IDE
# ------------------------------------------------------------------ #
.idea/
.vscode/
*.iml

# ------------------------------------------------------------------ #
# Raw sequencing data & large inputs (never commit these)
#   FASTQ can be regenerated/downloaded; keep the repo lean.
# ------------------------------------------------------------------ #
raw Data/
raw_data/
uploads/
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# ------------------------------------------------------------------ #
# QIIME2 artifacts, classifiers and pipeline outputs (large/binary)
# ------------------------------------------------------------------ #
data/
results/
*.qza
*.qzv
*.biom
classifiers/*.qza

# Generated QC / report artifacts
*_fastqc.html
*_fastqc.zip

# ------------------------------------------------------------------ #
# Vendored external tool: picrust2 ships its OWN git repo.
#   A nested .git turns it into an embedded repo and breaks `git add`.
#   Install picrust2 via conda instead (see environment.yml), or if you
#   must keep it in-tree, run:  rm -rf picrust2/.git  and un-ignore below.
# ------------------------------------------------------------------ #
picrust2/

# ------------------------------------------------------------------ #
# Local config with secrets / machine-specific overrides
# ------------------------------------------------------------------ #
config.local.yaml
.env
*.key

# ------------------------------------------------------------------ #
# OS cruft
# ------------------------------------------------------------------ #
.DS_Store
Thumbs.db